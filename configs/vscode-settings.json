{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.formatOnSaveMode": "file",

  "editor.acceptSuggestionOnEnter": "on",
  "editor.tabCompletion": "on",
  "editor.suggestSelection": "first",

  "editor.fontFamily": "Cascadia Code Pl",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.letterSpacing": 0.3,
  "editor.lineHeight": 22,

  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.wordWrap": "on",
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  "editor.autoIndent": "full",

  "editor.cursorStyle": "line",
  "editor.cursorWidth": 3,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",

  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.suppressSuggestions": true,

  "editor.parameterHints.enabled": true,
  "editor.smoothScrolling": true,

  "editor.lineNumbers": "on",
  "editor.renderWhitespace": "none",

  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true,
  },

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },

  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "top",
  "workbench.startupEditor": "none",
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.enablePreview": false,
  "workbench.tree.indent": 8,

  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": false,

  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/__pycache__": true,
    "**/dist": true,
    "**/.next": true,
    "**/node_modules": false,
  },
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "python": true,
  },

  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",
  "prettier.semi": true,
  "prettier.arrowParens": "always",
  "prettier.tabWidth": 2,
  "prettier.printWidth": 100,
  "prettier.useTabs": false,

  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.alwaysShowStatus": true,

  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "No italics",
        "scope": [
          "comment",
          "keyword",
          "variable.language",
          "meta.embedded",
          "meta.embedded.block",
          "meta.function-call",
          "meta.function-call.generic",
          "meta.function-call.constructor",
          "meta.function-call.static",
          "meta.function-call.instance",
          "entity.name.class",
          "entity.other.attribute-name",
        ],
        "settings": {
          "fontStyle": "",
        },
      },
    ],
  },
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "breadcrumbs.enabled": true,

  "editor.mouseWheelZoom": true,

  "files.associations": {
    "*.page-template": "vue",
    "*.layout-template": "vue",
    "*.vue": "vue",
    ".env*": "dotenv",
    "*.prisma": "chatagent",
  },

  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",

  "javascript.suggest.enabled": true,
  "javascript.suggest.names": true,
  "javascript.autoClosingTags": true,
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,

  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "javascriptreact": "html",
  },

  "editor.gotoLocation.multipleDefinitions": "goto",

  "typescript.preferences.importModuleSpecifier": "relative",
  "javascript.preferences.importModuleSpecifier": "relative",

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  "editor.minimap.enabled": false,
  "workbench.colorCustomizations": {},
  "conventionalCommits.lineBreak": "\\n",
  "settingsSync.ignoredExtensions": [],
  "json.schemas": [],
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "dotenv.enableAutocloaking": false,
  "workbench.iconTheme": "material-icon-theme",
  "csharp.suppressProjectJsonWarning": true,
  // "editor.fontLigatures": false,
  "catppuccin.italicKeywords": false,
  "catppuccin.italicFunctions": false,
  "catppuccin.italicComments": false,
  "catppuccin.italicStrings": false,
  "catppuccin.italicVariables": false,
  "catppuccin.italicTypes": false,
  "editor.semanticHighlighting.enabled": false,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
    },
    "Command Prompt": {
      "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"],
      "args": [],
      "icon": "terminal-cmd",
    },
    "Git Bash": {
      "source": "Git Bash",
      "icon": "terminal-git-bash",
    },
    "Ubuntu (WSL)": {
      "path": "C:\\WINDOWS\\System32\\wsl.exe",
      "args": ["-d", "Ubuntu"],
    },
  },
  "security.workspace.trust.untrustedFiles": "open",
  "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
  "github.copilot.chat.alternateGptPrompt.enabled": true,
  "mcpServers": {},
  "editor.inlineSuggest.edits.showCollapsed": true,
  "tabnine.experimentalAutoImports": true,
  "workbench.editor.empty.hint": "hidden",
  "cSpell.userWords": ["uuidv"],
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "terminal.integrated.initialHint": false,
  "window.menuBarVisibility": "compact",
  "extensions.ignoreRecommendations": true,
  "terminal.integrated.profiles.linux": {
    "bash": {
      "path": "/usr/bin/bash",
    },
    "zsh": {
      "path": "/usr/bin/zsh",
    },
    "fish": {
      "path": "fish",
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux",
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell",
    },
    "bash (2)": {
      "path": "/usr/bin/bash",
    },
    "rbash (2)": {
      "path": "/usr/bin/rbash",
    },
  },
  "terminal.integrated.defaultProfile.linux": "bash",
  "diffEditor.codeLens": true,
  "terminal.integrated.fontFamily": " \"Cascadia Code PL\"",
  "workbench.colorTheme": "GitHub Dark Mode",
  "workbench.statusBar.visible": false,
  "settingsSync.ignoredSettings": [],
  "editor.linkedEditing": true,
}
